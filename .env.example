# ==============================================================================
# MongoDB Atlas Configuration Template
# ==============================================================================
# Copy this file to .env.local and populate with your actual Atlas credentials.
# Do NOT commit your actual .env.local file containing passwords to Git!

# MongoDB Atlas Connection String
# Replace <username>, <password>, and your-db-name with your database settings.
MONGODB_URI="mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/your-db-name?retryWrites=true&w=majority"
